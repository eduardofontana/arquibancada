API_FOOTBALL_KEY=

# API-Football defaults: Brasileirao Serie A = 71.
# Add more leagues with commas, but each extra league increases request usage.
API_FOOTBALL_LEAGUE_IDS=71
API_FOOTBALL_SEASON=2026

# Economic mode for the free plan.
# Fixtures: 1 request per cache cycle per league. 900s ~= up to 96 requests/day.
# Standings: low churn, so keep a long cache.
API_FOOTBALL_FIXTURES_REVALIDATE_SECONDS=900
API_FOOTBALL_STANDINGS_REVALIDATE_SECONDS=43200

# Date window for fixtures shown in the app.
API_FOOTBALL_WINDOW_PAST_DAYS=2
API_FOOTBALL_WINDOW_FUTURE_DAYS=7
